# Valor 2.0 — Production Environment Variables
# ==============================================
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.

# --- Database (Neon PostgreSQL) ---
# Get from: console.neon.tech → your project → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# --- Auth (Auth.js) ---
# Generate with: openssl rand -hex 32
AUTH_SECRET=your-auth-secret
# For local dev: http://localhost:9002
# For production: https://your-app.vercel.app
AUTH_URL=http://localhost:9002

# --- Google Gemini ---
# Get from: aistudio.google.com → Get API key
GEMINI_API_KEY=your-gemini-api-key

# --- Coinbase CDP ---
# Get from: portal.cdp.coinbase.com → API Keys
CDP_API_KEY_NAME=your-cdp-api-key-name
CDP_API_KEY_PRIVATE_KEY=your-cdp-private-key
# 'base' for mainnet, 'base-sepolia' for testnet
CDP_NETWORK_ID=base

# --- Upstash QStash ---
# Get from: upstash.com → QStash
QSTASH_TOKEN=your-qstash-token
QSTASH_CURRENT_SIGNING_KEY=your-current-signing-key
QSTASH_NEXT_SIGNING_KEY=your-next-signing-key

# --- App ---
# For local dev: http://localhost:9002
# For production: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:9002
# Generate with: openssl rand -hex 32 (any 32-char random string)
CRON_SECRET=your-cron-secret
