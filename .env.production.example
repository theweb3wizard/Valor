# Valor 2.0 — Production Environment Variables
# ==============================================
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.

# --- Database (Neon PostgreSQL) ---
# Get from: console.neon.tech → your project → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# --- Auth (Auth.js) ---
# Generate with: openssl rand -hex 32
AUTH_SECRET=your-auth-secret
# For local dev: http://localhost:9002
# For production: https://valor-tgbot.vercel.app
AUTH_URL=https://valor-tgbot.vercel.app

# --- Google Gemini ---
# Get from: aistudio.google.com → Get API key
GEMINI_API_KEY=your-gemini-api-key

# --- Treasury Wallet (Base chain) ---
# Generate with: openssl rand -hex 32 (prepend 0x)
# This wallet holds USDC for tipping and ETH for gas on Base.
# Fund it with USDC (Base) and a tiny amount of ETH for gas (~$0.10).
TREASURY_PRIVATE_KEY=0xyour-private-key

# --- Upstash QStash ---
# Get from: upstash.com → QStash
QSTASH_TOKEN=your-qstash-token
QSTASH_CURRENT_SIGNING_KEY=your-current-signing-key
QSTASH_NEXT_SIGNING_KEY=your-next-signing-key

# --- App ---
# For local dev: http://localhost:9002
# For production: https://valor-tgbot.vercel.app
NEXT_PUBLIC_APP_URL=https://valor-tgbot.vercel.app
# Generate with: openssl rand -hex 32 (any 32-char random string)
CRON_SECRET=your-cron-secret
